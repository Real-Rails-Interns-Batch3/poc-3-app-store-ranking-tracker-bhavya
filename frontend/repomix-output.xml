"use client";

import dynamic from "next/dynamic";
import { useEffect, useState } from "react";
import { Sidebar } from "@/components/Sidebar";
import { Topbar } from "@/components/Topbar";
import FilterPanel from "@/components/Filterpanel";

const MapStage = dynamic(() => import("@/components/MapStage"), {
  ssr: false,
});

type CountryOption = {
  country_id: number;
  country_name: string;
};

export default function Page() {
  const API =
    process.env.NEXT_PUBLIC_API_BASE_URL || "http://localhost:8000";

  const [stationCount, setStationCount] = useState(0);
  const [refreshKey, setRefreshKey] = useState(0);
  const [panelOpen, setPanelOpen] = useState(true);

  const [filters, setFilters] = useState({
    level: "ALL",
    region: [] as string[],
    operator: "",
  });

  const [operatorId, setOperatorId] = useState<number | null>(null);
  const [backendMetrics, setBackendMetrics] = useState<any>(null);
  const [countries, setCountries] = useState<CountryOption[]>([]);
  const [topOperators, setTopOperators] = useState<any[]>([]);
  const [filteredTotal, setFilteredTotal] = useState<number | null>(null);

  const triggerRefresh = () => setRefreshKey((p) => p + 1);

  /* ---------------- FETCH METRICS ---------------- */
  useEffect(() => {
    fetch(`${API}/api/metrics`)
      .then((r) => r.json())
      .then(setBackendMetrics)
      .catch(() => setBackendMetrics(null));
  }, [refreshKey]);

  /* ---------------- COUNTRIES ---------------- */
  useEffect(() => {
    fetch(`${API}/api/filters/countries`)
      .then((r) => r.json())
      .then(setCountries)
      .catch(() => {});
  }, []);

  /* ---------------- OPERATOR RESOLVE ---------------- */
  useEffect(() => {
    const q = filters.operator?.trim();
    if (!q) return setOperatorId(null);

    fetch(`${API}/api/filters/operators?q=${q}`)
      .then((r) => r.json())
      .then((data) => {
        if (!Array.isArray(data) || !data.length) return setOperatorId(null);

        const exact = data.find(
          (o: any) => o.operator_name?.toLowerCase() === q.toLowerCase()
        );

        setOperatorId(exact?.operator_id ?? data[0].operator_id);
      })
      .catch(() => setOperatorId(null));
  }, [filters.operator]);

  /* ---------------- TOP OPERATORS ---------------- */
  useEffect(() => {
    let url = `${API}/api/top-operators`;
    const params = new URLSearchParams();

    filters.region.forEach((id) => {
      const n = Number(id);
      if (!isNaN(n)) params.append("country_id", n.toString());
    });

    if (operatorId) params.append("operator_id", operatorId.toString());
    if (params.toString()) url += `?${params.toString()}`;

    fetch(url)
      .then((r) => r.json())
      .then((d) => setTopOperators(Array.isArray(d) ? d : []))
      .catch(() => setTopOperators([]));
  }, [filters, operatorId]);

  /* ---------------- COUNT ---------------- */
  useEffect(() => {
    let url = `${API}/api/stations/count`;
    const params = new URLSearchParams();

    filters.region.forEach((id) => {
      const n = Number(id);
      if (!isNaN(n)) params.append("country_id", n.toString());
    });

    if (operatorId) params.append("operator_id", operatorId.toString());
    if (params.toString()) url += `?${params.toString()}`;

    fetch(url)
      .then((r) => r.json())
      .then((d) => setFilteredTotal(d?.total ?? 0))
      .catch(() => setFilteredTotal(null));
  }, [filters, operatorId]);

  const isFiltered = filters.region.length > 0 || operatorId !== null;

  const totalStations =
    isFiltered
      ? filteredTotal ?? 0
      : backendMetrics?.total_stations ?? 0;

  const metrics = {
    total_stations: totalStations,
    dc_fast: Math.floor(totalStations * 0.6),
    operators: isFiltered
      ? topOperators.length
      : backendMetrics?.operators ?? 0,
    countries: backendMetrics?.countries ?? 0,
  };

  return (
    <div className="cinematic-root bg-[#020617] text-white">

      {/* HEADER */}
      <header className="cinematic-header">
        <div>
          <h1>EV INTELLIGENCE RAIL</h1>
          <p>Next-Gen Charging Infrastructure System</p>
        </div>

        <button
          onClick={() => setPanelOpen(!panelOpen)}
          className="cinematic-btn"
        >
          TOGGLE PANEL
        </button>
      </header>

      {/* FILTER */}
      <div className="filter-wrap">
        <FilterPanel
          filters={filters}
          onChange={setFilters}
          countryOptions={countries}
        />
      </div>

      {/* MAP ENGINE LAYERS */}
      <div className="map-layer">
        <MapStage
          key={refreshKey}
          onCountChange={setStationCount}
          filters={{
            ...filters,
            operator: operatorId ? operatorId.toString() : "",
          }}
        />
      </div>

      {/* OVERLAY GLOW */}
      <div className="cinematic-overlay" />

      {/* PANEL */}
      <div
        className={`panel ${panelOpen ? "open" : "closed"}`}
      >
        <button
          onClick={() => setPanelOpen(false)}
          className="close-btn"
        >
          ✕
        </button>

        <Sidebar
          metrics={metrics}
          onRefresh={triggerRefresh}
          topOperators={topOperators}
        />

        {/* DEVELOPER SIGNATURE */}
        <div className="signature text-yellow-500">
          <h3>// DEVELOPER SIGNATURE</h3>
          <p className="text-white">Architect: Bhavya S Shaji</p>
          <p className="text-white">Batch: Batch 3 Interns</p>
          <p className="text-white">Stack: Next.js · FastAPI · Tailwind</p>
          <p className="text-white">Rail: EV Cinematic Intelligence System v2</p>
        </div>
      </div>

      {!panelOpen && (
        <button
          className="open-btn"
          onClick={() => setPanelOpen(true)}
        >
          OPEN PANEL
        </button>
      )}

      {/* DEVELOPER SIGNATURE (FLOATING FIXED) */}
      <div className="fixed bottom-4 left-4 z-[9999] bg-black/60 backdrop-blur-md p-3 rounded-xl border border-yellow-500/30 text-xs">
        <p className="text-yellow-500 font-bold">// DEVELOPER SIGNATURE</p>
        <p>Architect: Bhavya S Shaji</p>
        <p>Batch: Batch 3 Interns</p>
        <p>Stack: Next.js · FastAPI · Tailwind</p>
        <p>System: Cinematic EV Rail v2</p>
      </div>
    </div>
  );
}
