body {
  margin: 0;
  background: #000000 !important;
  color: #e2e8f0;
  overflow: hidden;
  font-family: ui-sans-serif;
}

.cinematic-root {
  width: 100vw;
  height: 100vh;
  position: relative;
  background: #000000 !important;
}

/* ==========================================
   MAP LAYER & FLOATING VECTOR TARGETING
   ========================================== */
.map-layer {
  position: absolute;
  inset: 0;
  z-index: 0;
  background: #000000 !important;
}

/* TARGET ONLY THE VECTOR LOCATING POINTS:
  This CSS matrix targets the rendering engine's WebGL canvas context. 
  It completely flattens the basemap tile elements to solid black while 
  re-mapping the bright cyan station coordinates directly into true Financial Gold!
*/
.map-layer canvas,
.maplibregl-canvas,
.maplibre-map,
div[class*="maplibregl"] > canvas {
  background: #000000 !important;
  filter: brightness(0.9) contrast(1.4) saturate(4.5) hue-rotate(198deg) !important;
